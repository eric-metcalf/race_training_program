# Local dev — copy to .env and fill in
DATABASE_URL=jdbc:postgresql://localhost:5432/training
DATABASE_USER=training
DATABASE_PASSWORD=training

# App
APP_URL=http://localhost:8081
HTTP_PORT=8081
ATHLETE_ID=1

# Strava — register an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Random opaque string you choose; sent back by Strava on webhook verify
STRAVA_VERIFY_TOKEN=change-me-to-a-random-string
